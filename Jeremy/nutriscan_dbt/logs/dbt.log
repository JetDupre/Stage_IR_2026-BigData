  create view "nutriScan"."main_staging"."stg_categories__dbt_tmp" as (
    

SELECT
    code                                  AS product_code,
    categories_tags[1]                    AS category_tag,   -- Accès direct au tableau natif
    string_split(categories, ',')[1]      AS category_label  -- Reste correct car 'categories' est un VARCHAR
