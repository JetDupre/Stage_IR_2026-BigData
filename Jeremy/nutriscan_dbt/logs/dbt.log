      "nutriScan"."main_marts"."dim_brand__dbt_tmp"
  
    as (
      

WITH marques_distinctes AS (
    SELECT
        brand_tag,
        MAX(brand_name) AS brand_name
    FROM "nutriScan"."main_staging"."stg_brands"
    WHERE brand_tag IS NOT NULL
