    create  table
      "nutriScan"."main_marts"."fact_nutrition__dbt_tmp"
  
    as (
      

WITH nutrition      AS (SELECT * FROM "nutriScan"."main_staging"."stg_nutrition"),
     countries      AS (SELECT * FROM "nutriScan"."main_staging"."stg_countries"),
     stg_cats       AS (SELECT * FROM "nutriScan"."main_staging"."stg_categories"),
     stg_brnds      AS (SELECT * FROM "nutriScan"."main_staging"."stg_brands"),
     stg_dt         AS (SELECT * FROM "nutriScan"."main_staging"."stg_date"),
     
     dim_p          AS (SELECT * FROM "nutriScan"."main_marts"."dim_product"),
     dim_c          AS (SELECT * FROM "nutriScan"."main_marts"."dim_category"),
     dim_b          AS (SELECT * FROM "nutriScan"."main_marts"."dim_brand"),
     dim_co         AS (SELECT * FROM "nutriScan"."main_marts"."dim_country"),
     dim_d          AS (SELECT * FROM "nutriScan"."main_marts"."dim_date")

SELECT
    -- Clé primaire artificielle de fait
    ROW_NUMBER() OVER (ORDER BY n.product_code, c.country_tag) AS nutrition_sk,
    
    -- Clés étrangères résolues linéairement
    p.product_sk,
    dc.category_sk,
    dco.country_sk,
    db.brand_sk,
    d.date_sk,
    
    -- Métriques (Alias miroirs du .drawio)
    n.energy_kcal,
    n.fat_100g,
    n.saturated_fat_100g,
    n.sugar_100g,
    n.salt_100g,
    n.proteins_100g,
    n.fiber_100g,
    n.nutriscore_score

FROM nutrition n
-- Grain : un produit x un pays
JOIN countries c ON n.product_code = c.product_code

-- Jointures directes et sécurisées à 1 clé unique (0% de risque de fan-out)
LEFT JOIN dim_p p     ON n.product_code = p.product_code
LEFT JOIN dim_co dco  ON c.country_tag  = dco.country_tag

-- Récupération des tags intermédiaires du produit pour mapper la clé surrogate
LEFT JOIN stg_cats cat ON n.product_code = cat.product_code
LEFT JOIN dim_c dc     ON cat.category_tag = dc.category_tag

LEFT JOIN stg_brnds br ON n.product_code = br.product_code
LEFT JOIN dim_b db     ON br.brand_tag   = db.brand_tag

LEFT JOIN stg_dt dt    ON n.product_code = dt.product_code
LEFT JOIN dim_d d      ON dt.date_sk     = d.date_sk
    );
  
  
