    create  table
      "nutriScan"."main_marts"."dim_country__dbt_tmp"
  
    as (
      

WITH pays_distincts AS (
    SELECT DISTINCT country_tag
    FROM "nutriScan"."main_staging"."stg_countries"
    WHERE country_tag IS NOT NULL
)
SELECT
    ROW_NUMBER() OVER (ORDER BY country_tag) AS country_sk,
    country_tag,
    -- Utilisation de ta formule dynamique pour isoler et formater le nom du pays
    UPPER(SUBSTR(country_tag, 4, 1)) || SUBSTR(country_tag, 5) AS country_name
FROM pays_distincts
    );
  
  
