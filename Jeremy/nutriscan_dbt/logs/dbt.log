SELECT
    ROW_NUMBER() OVER (ORDER BY country_tag) AS country_sk,
    country_tag,
    CASE country_tag
        WHEN 'en:france' THEN 'France'
        WHEN 'en:belgium' THEN 'Belgique'
        WHEN 'en:spain' THEN 'Espagne'
        WHEN 'en:germany' THEN 'Allemagne'
        WHEN 'en:italy' THEN 'Italie'
        ELSE UPPER(SUBSTR(country_tag, 4, 1)) || SUBSTR(country_tag, 5)
    END AS country_name
FROM (
    SELECT DISTINCT country_tag 
    FROM "nutriScan"."main_staging"."stg_countries"
    WHERE country_tag IS NOT NULL
)
    );
  
  
