[0m14:47:30.881182 [debug] [Thread-2 (]: On model.nutriscan_dbt.fact_nutrition: /* {"app": "dbt", "dbt_version": "1.8.7", "profile_name": "nutriscan_dbt", "target_name": "dev", "node_id": "model.nutriscan_dbt.fact_nutrition"} */

  
    
    

    create  table
      "nutriScan"."main_marts"."fact_nutrition__dbt_tmp"
  
    as (
      

WITH nutrition  AS (SELECT * FROM "nutriScan"."main_staging"."stg_nutrition"),
     countries  AS (SELECT * FROM "nutriScan"."main_staging"."stg_countries"),
     produits   AS (SELECT * FROM "nutriScan"."main_marts"."dim_product"),
     categories AS (SELECT * FROM "nutriScan"."main_marts"."dim_category"),
     marques    AS (SELECT * FROM "nutriScan"."main_marts"."dim_brand"),
     pays       AS (SELECT * FROM "nutriScan"."main_marts"."dim_country"),
     dates      AS (SELECT * FROM "nutriScan"."main_marts"."dim_date")

SELECT
    ROW_NUMBER() OVER (ORDER BY n.product_code, c.country_tag) AS nutrition_sk,
    
    p.product_sk,
    dc.category_sk,
    db.brand_sk,
    dco.country_sk,
    d.date_sk,
    
    n.energy_kcal,
    n.fat_100g,
    n.saturated_fat_100g,
    n.sugar_100g,
    n.salt_100g,
    n.proteins_100g,
    n.fiber_100g,
    n.nutriscore_score

FROM nutrition n
-- On éclate au grain (Produit x Pays)
JOIN countries c        ON n.product_code = c.product_code

-- Les jointures simples prévues par le workshop (toutes sur product_code)
LEFT JOIN produits p    ON n.product_code = p.product_code
LEFT JOIN categories dc ON n.product_code = dc.product_code
LEFT JOIN marques db    ON n.product_code = db.product_code

-- Pour le pays, on associe le produit ET le tag pays pour être précis
LEFT JOIN pays dco      ON n.product_code = dco.product_code AND c.country_tag = dco.country_tag

-- Jointure sur le calendrier
LEFT JOIN dates d       ON CAST(to_timestamp(n.last_modified_t) AS DATE) = d.date_value
    );
  
  
