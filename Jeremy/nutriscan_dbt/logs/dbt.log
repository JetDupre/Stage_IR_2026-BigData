    create  table
      "nutriScan"."main_marts"."dim_category__dbt_tmp"
  
    as (
      

WITH categories_uniques AS (
    SELECT
        category_label,
        MIN(category_tag) AS category_tag -- Associe un tag unique par libellé nettoyé
    FROM "nutriScan"."main_staging"."stg_categories"
    GROUP BY category_label
)
SELECT
    ROW_NUMBER() OVER (ORDER BY category_label) AS category_sk,
    category_tag,
    category_label
FROM categories_uniques
    );
  
  
