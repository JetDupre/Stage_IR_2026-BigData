    create  table
      "nutriScan"."main_marts"."fact_nutrition__dbt_tmp"
  
    as (
      

WITH nutrition  AS (SELECT * FROM "nutriScan"."main_staging"."stg_nutrition"),
     countries  AS (SELECT * FROM "nutriScan"."main_staging"."stg_countries"),
     
     -- Import direct des dimensions Gold finalisées (uniques et propres)
     dim_p      AS (SELECT * FROM "nutriScan"."main_marts"."dim_product"),
     dim_c      AS (SELECT * FROM "nutriScan"."main_marts"."dim_category"),
     dim_b      AS (SELECT * FROM "nutriScan"."main_marts"."dim_brand"),
     dim_co     AS (SELECT * FROM "nutriScan"."main_marts"."dim_country"),
     dim_d      AS (SELECT * FROM "nutriScan"."main_marts"."dim_date")

SELECT
    -- Génération linéaire ultra-rapide de la clé de fait
    ROW_NUMBER() OVER (ORDER BY n.product_code) AS nutrition_sk,
    
    -- Résolution des clés étrangères en 1 seule passe directe
    p.product_sk,
    dc.category_sk,
    db.brand_sk,
    dco.country_sk,
    d.date_sk,
    
    -- Métriques (Alias miroirs conformes à ton .drawio)
    n.energy_kcal,
    n.fat_100g,
    n.saturated_fat_100g,
    n.sugar_100g,
    n.salt_100g,
    n.proteins_100g,
    n.fiber_100g,
    n.nutriscore_score

FROM nutrition n
-- Grain de base : Produit x Pays
JOIN countries c ON n.product_code = c.product_code

-- Jointures directes "Indexed-like" ultra-performantes
LEFT JOIN dim_p p    ON n.product_code = p.product_code
LEFT JOIN dim_co dco ON c.country_tag  = dco.country_tag

-- Jointure temporelle sur la clé intelligente AAAAMMDD calculée dans stg_nutrition
LEFT JOIN dim_d d    ON CAST(strftime(CAST(to_timestamp(n.last_modified_t) AS DATE), '%Y%m%d') AS INTEGER) = d.date_sk

-- Pour la catégorie et la marque, on s'appuie directement sur les SK résolues dans les dimensions
LEFT JOIN dim_c dc   ON n.product_code = dc.product_code
LEFT JOIN dim_b db   ON n.product_code = db.product_code
    );
  
  
