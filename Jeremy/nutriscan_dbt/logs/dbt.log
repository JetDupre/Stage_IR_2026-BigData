    create  table
      "nutriScan"."main_marts"."sem_sel_moyen_par_categorie__dbt_tmp"
  
    as (
      -- moyenne de salt_g par categorie



SELECT
    dc.category_label,
    ROUND(AVG(fn.salt_100g), 4) AS sel_moyen_g
FROM "nutriScan"."main_marts"."fact_nutrition" fn
JOIN "nutriScan"."main_marts"."dim_category" dc ON fn.category_sk = dc.category_sk
WHERE fn.salt_100g IS NOT NULL
GROUP BY dc.category_label
    );
  
  
[0m14:47:30.542589 [debug] [Thread-2 (]: On model.nutriscan_dbt.sem_nutriscore_moyen: /* {"app": "dbt", "dbt_version": "1.8.7", "profile_name": "nutriscan_dbt", "target_name": "dev", "node_id": "model.nutriscan_dbt.sem_nutriscore_moyen"} */

  
    
    

    create  table
      "nutriScan"."main_marts"."sem_nutriscore_moyen__dbt_tmp"
  
    as (
      -- Elle calcule le nutriscore moyen par categorie, marque et pays en une seule requete.



SELECT
    dc.category_label,
    db.brand_name,
    dco.country_name,
    dd.year,
    dd.month,
    ROUND(AVG(fn.nutriscore_score), 2)  AS nutriscore_moyen,
    COUNT(DISTINCT fn.product_sk)        AS nb_produits
FROM "nutriScan"."main_marts"."fact_nutrition" fn
JOIN "nutriScan"."main_marts"."dim_category"  dc  ON fn.category_sk  = dc.category_sk
JOIN "nutriScan"."main_marts"."dim_brand"     db  ON fn.brand_sk     = db.brand_sk
JOIN "nutriScan"."main_marts"."dim_country"   dco ON fn.country_sk   = dco.country_sk
JOIN "nutriScan"."main_marts"."dim_date"      dd  ON fn.date_sk      = dd.date_sk
WHERE fn.nutriscore_score IS NOT NULL
GROUP BY dc.category_label, db.brand_name, dco.country_name, dd.year, dd.month
    );
  
  
