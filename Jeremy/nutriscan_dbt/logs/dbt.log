      "nutriScan"."main_marts"."sem_sel_moyen_par_categorie__dbt_tmp"
  
    as (
      -- moyenne de salt_g par categorie



SELECT
    dc.category_label,
    ROUND(AVG(fn.salt_100g), 4) AS sel_moyen_g
FROM "nutriScan"."main_marts"."fact_nutrition" fn
JOIN "nutriScan"."main_marts"."dim_category" dc ON fn.category_sk = dc.category_sk
WHERE fn.salt_100g IS NOT NULL
GROUP BY dc.category_label
    );
  
  
